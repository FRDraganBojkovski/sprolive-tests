n        }\n\n        .panel-heading {\n            padding: 5px 15px !important;\n            background: #053c81 !important;\n        }\n\n        .panel-tabs > li {\n            float: left;\n            margin-bottom: -1px;\n        }\n\n            .panel-tabs > li > a {\n                margin-right: 2px;\n                margin-top: 0;\n                line-height: .85;\n                border: 1px solid transparent;\n                border-radius: 4px 4px 0 0;\n                color: #ffffff;\n            }\n\n                .panel-tabs > li > a:hover {\n                    border-color: transparent !important;\n                    color: #ffffff !important;\n                    background-color: transparent !important;\n                }\n\n        .nav > li > a {\n            padding: 10px 10px !important;\n        }\n\n        .btn.btn-primary {\n            background-color: #053c81 !important;\n            border-color: #053c81 !important;\n            background-image: none !important;\n        }\n\n        .panel-tabs > li.active > a,\n        .panel-tabs > li.active > a:hover,\n        .panel-tabs > li.active > a:focus {\n            color: #fff;\n            cursor: default;\n            -webkit-border-radius: 2px;\n            -moz-border-radius: 2px;\n            border-radius: 2px;\n            background-color: rgba(255,255,255, .23);\n            border-bottom-color: transparent;\n        }\n\n        .panel-primary {\n            border-color: #053c81 !important;\n        }\n\n        .welcomeuser {\n            color: #053c81 !important;\n            font-weight: 500;\n            font-size: 14pt;\n        }\n\n        #notif-content2 {\n            margin-left: 3.5rem !important;\n            margin-top: 10px;\n        }\n\n        #notif-content_notify {\n            left: 200px !important;\n        }\n\n        .recent_holder {\n            margin-left: 200px;\n            margin-top: 5px !important;\n            float: left;\n        }\n\n        .notify_holder {\n            margin-left: 10px;\n            float: left;\n            margin-top: -2px;\n        }\n\n        @media only screen and (max-width: 600px) {\n            .notify_holder {\n                margin-left: 0 !important;\n                margin-top: 0px;\n                width: 55px;\n                text-align: center;\n            }\n        }\n\n        /*.logo {\n            margin: 8px 0 0 10px;\n        }*/\n\n        .main-wrap {\n            height: auto !important;\n        }\n\n        body {\n            background: #EDECEC;\n        }\n\n        .nav-tabs {\n            display: flex;\n            width: 100%;\n            overflow-x: auto;\n            border-bottom: 2px solid #DDD;\n            -ms-overflow-style: none; /*// IE 10+*/\n            overflow: -moz-scrollbars-none; /*// Firefox*/\n        }\n\n            .nav-tabs > li.active > a,\n            .nav-tabs > li.active > a:focus,\n            .nav-tabs > li.active > a:hover {\n                border-width: 0;\n            }\n\n            .nav-tabs > li > a {\n                border: none;\n                color: #666;\n                line-height: 1.528571 !important;\n                border-radius: 0px 0px 0 0 !important;\n            }\n\n                .nav-tabs > li.active > a,\n                .nav-tabs > li > a:hover {\n                    border: none;\n                    color: #053c81 !important;\n                    background: transparent;\n                }\n\n                .nav-tabs > li > a::after {\n                    content: \"\";\n                    background: #053c81;\n                    height: 2px;\n                    position: absolute;\n                    width: 100%;\n                    left: 0px;\n                    bottom: 1px;\n                    transition: all 250ms ease 0s;\n                    transform: scale(0);\n                }\n\n            .nav-tabs > li.active > a::after,\n            .nav-tabs > li:hover > a::after {\n                transform: scale(1);\n            }\n\n        .tab-nav > li > a::after {\n            background: #21527d none repeat scroll 0% 0%;\n            color: #fff;\n        }\n\n        .tab-pane {\n            padding: 10px 0;\n        }\n\n\n\n        .nav-tabs::-webkit-scrollbar {\n            display: none; /*Safari and Chrome*/\n        }\n\n        .container {\n            background: #fff;\n            /*height: 100%;*/\n            box-shadow: 0px 2px 4px 0px #ccc;\n        }\n\n        /*ul.ss-navbar .ss-navitem .ss-nav-link.icon-link {\n            padding: 1.4rem 1rem 1.4rem 0.45rem !important;\n        }*/\n\n        .badge-danger {\n            color: #fff;\n            background-color: #D71A21 !important;\n        }\n\n        /*.badge-primary {\n            color: #fff;\n            background-color: #053c81 !important;\n        }*/\n\n        #msgnotif-group span#msgsactivity {\n            margin:13px 0 0 !important;\n        }\n\n        .secondary-navbar {\n            padding-right: 8px !important;\n        }\n\n        ul.ss-navbar .ss-navitem {\n            padding: 1px 0px;\n        }\n\n        #msgnotif-content {\n            text-align:left !important;\n        }\n\n\n        /*.card {\n            background: #FFF none repeat scroll 0% 0%;\n            box-shadow: 0px 1px 3px rgba(0, 0, 0, 0.3);\n            margin-bottom: 30px;\n        }*/\n       .loader {\n            border: 16px solid #f3f3f3;\n            border-radius: 50%;\n            border-top: 16px solid #1685bc;\n            border-bottom: 16px solid #1685bc;\n            width: 50px;\n            height: 50px;\n            -webkit-animation: spin 2s linear infinite;\n            animation: spin 2s linear infinite;\n        }      \n\n       .loading-circle {\n    display: block;\n    left: 50%;\n    top: 10%;\n    width: 125px;\n    height: 125px;\n    margin: -62.5px 0 0 -62.5px;\n    border: 3px solid #78b428;\n}\n\n    .loading-circle:after {\n