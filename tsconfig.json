{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": ["server.ts", "utils/**/*.ts", "page-objects/**/*.ts", "tests/**/*.ts", "playwright.config.ts", "test-options.ts"],
  "exclude": ["node_modules", "dist"]
}
